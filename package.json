{
  "name": "multi-browser-workspace-platform",
  "version": "1.0.0",
  "description": "Enterprise Multi Browser Workspace Platform - Professional browser profile management system",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:renderer": "vite",
    "build": "vite build && electron-builder",
    "build:renderer": "vite build",
    "build:electron": "electron-builder",
    "lint": "eslint src/**/*.{js,jsx,ts,tsx}",
    "test": "jest"
  },
  "keywords": [
    "browser",
    "profile-manager",
    "multi-browser",
    "enterprise",
    "automation",
    "workspace"
  ],
  "author": "Rena Ernawati",
  "license": "MIT",
  "dependencies": {
    "electron": "^28.0.0",
    "electron-store": "^8.1.0",
    "playwright": "^1.40.0",
    "playwright-core": "^1.40.0",
    "better-sqlite3": "^9.2.0",
    "zustand": "^4.4.7",
    "@tanstack/react-query": "^5.17.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "axios": "^1.6.2",
    "bullmq": "^5.1.0",
    "ioredis": "^5.3.2",
    "uuid": "^9.0.1",
    "dayjs": "^1.11.10",
    "lodash": "^4.17.21",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.1.14",
    "puppeteer-core": "^21.6.0",
    "chrome-remote-interface": "^0.33.0"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron-builder": "^24.9.0",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.0",
    "jest": "^29.7.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16"
  },
  "build": {
    "appId": "com.renaernawati.browser-workspace",
    "productName": "Multi Browser Workspace Platform",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "profiles/**/*",
      "database/**/*",
      "extensions/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
