# Multi Browser Workspace Platform - Environment Configuration

# Application Settings
APP_NAME=Multi Browser Workspace Platform
APP_VERSION=1.0.0
APP_ENV=development

# Database Settings
DB_PATH=./database/app.sqlite
DB_ENCRYPTION_KEY=your-encryption-key-here

# Browser Settings
DEFAULT_BROWSER_ENGINE=chromium
CHROMIUM_VERSION_PATH=./browser/chromium
MAX_CONCURRENT_BROWSERS=50
BROWSER_TIMEOUT=30000

# Proxy Settings
DEFAULT_PROXY_PROTOCOL=http
PROXY_TEST_TIMEOUT=10000
PROXY_ROTATION_ENABLED=false

# Resource Limits
MAX_RAM_USAGE_GB=16
MAX_CPU_USAGE_PERCENT=80
PROFILE_SUSPENSION_TIMEOUT=1800000

# Security
APP_PIN_ENABLED=true
SESSION_TIMEOUT=3600000
IPC_SECURE_MODE=true

# API Settings
API_PORT=3001
API_ENABLED=true
API_RATE_LIMIT=100

# Logging
LOG_LEVEL=info
LOG_PATH=./logs
LOG_RETENTION_DAYS=30

# Backup Settings
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=7

# Developer Settings
DEV_TOOLS_ENABLED=true
RELOAD_ON_CHANGE=true
DEBUG_MODE=false
